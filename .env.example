# DevisFlow — Exemple de variables d'environnement
# Copier ce fichier en .env et ajuster les valeurs

# === Chemins ===
# Binaire LibreOffice (utilisé pour la conversion DOCX → PDF)
# Linux par défaut : /usr/bin/soffice
# macOS : /Applications/LibreOffice.app/Contents/MacOS/soffice
# Windows : C:\Program Files\LibreOffice\program\soffice.exe
SOFFICE_BIN=/usr/bin/soffice

# === Base de données ===
# Par défaut : SQLite local
# DATABASE_URL=sqlite:///./storage/db/devisflow.db
#
# Pour PostgreSQL en production :
# DATABASE_URL=postgresql://devisflow_user:CHANGE_ME@db.example.com:5432/devisflow

# === Sécurité (à ajouter quand authentification implémentée) ===
# Générer avec : openssl rand -hex 32
SECRET_KEY=changez_moi_avec_openssl_rand_hex_32

# Origines CORS autorisées (séparées par des virgules)
# En dev : * (toutes), en prod : votre domaine
ALLOWED_ORIGINS=https://devisflow.votre-domaine.com

# === Logs ===
LOG_LEVEL=info
